name: ci
on:
  push:
  pull_request:
permissions:
  contents: read
jobs:
  validate:
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4
      - name: Validate toolchain
        shell: pwsh
        run: |
          $ErrorActionPreference='Stop'
          Set-StrictMode -Version Latest
          pwsh -NoProfile -NonInteractive -NoLogo -File tools/coprime.validate.ps1
