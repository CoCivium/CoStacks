{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PointerRegistryEntry",
  "type": "object",
  "required": [
    "asset_id",
    "title",
    "canonical_uri",
    "mirrors",
    "version",
    "sha256",
    "owner",
    "access_class",
    "last_verified_utc"
  ],
  "properties": {
    "asset_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "canonical_uri": {
      "type": "string",
      "minLength": 1
    },
    "mirrors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "access_class": {
      "type": "string",
      "enum": [
        "PUBLIC",
        "INTERNAL",
        "CONFIDENTIAL",
        "CROWN_JEWEL"
      ]
    },
    "last_verified_utc": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}