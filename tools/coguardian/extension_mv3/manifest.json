{
  "manifest_version": 3,
  "name": "CoGuardian (CoStacks)",
  "version": "0.1.0",
  "description": "Visible CoGuardian surface for CoStacks: quick actions + status.",
  "action": {
    "default_title": "CoGuardian",
    "default_popup": "popup.html",
    "default_icon": "icons/icon.ico"
  },
  "background": { "service_worker": "service_worker.js" },
  "permissions": ["storage","alarms"],
  "icons": { "128": "icons/icon.ico" }
}